GRUB_DEFAULT=saved
GRUB_SAVEDEFAULT=true

GRUB_TIMEOUT_STYLE=menu
GRUB_TIMEOUT=3
GRUB_DISTRIBUTOR="ThinkPad P1"

GRUB_PRELOAD_MODULES="part_gpt"

GRUB_CMDLINE_LINUX_DEFAULT="quiet splash loglevel=3 rd.systemd.show_status=auto rd.udev.log_priority=3 mitigations=off nowatchdog vt.global_cursor_default=0 mem_sleep_default=deep i915.enable_psr=0 i915.fastboot=1 nvidia-drm.modeset=1 nvidia.NVreg_PreserveVideoMemoryAllocations=1 nvidia.NVreg_DynamicPowerManagement=0x02 resume=UUID=e2995850-2a54-4d5c-a7f2-c673a6071aa5 resume_offset=13967360"

GRUB_TERMINAL_INPUT=console
#GRUB_TERMINAL_OUTPUT=console

# Se desactiva para evitar el retraso al cargar el SO
GRUB_GFXMODE=2560x1440
GRUB_GFXPAYLOAD_LINUX=keep

GRUB_DISABLE_RECOVERY=true
GRUB_DISABLE_OS_PROBER=false

# Normal: gris sobre negro
GRUB_COLOR_NORMAL="light-gray/black"

# Selección: rojo ThinkPad sobre negro
GRUB_COLOR_HIGHLIGHT="red/black"

GRUB_THEME="/usr/share/grub/themes/thinkpad/theme.txt"
