#!/bin/bash

# Genera una clave con Python y la copia al portapapeles
SECRET=$(python3 -c "
import secrets, string
chars = (string.ascii_letters + string.digits + string.punctuation).replace('\"','').replace(\"'\",'').replace('\\\\','')
print(''.join(secrets.choice(chars) for _ in range(64)))
")

# Copiar al portapapeles (requiere xclip o wl-copy según tu entorno)
echo -n "$SECRET" | xclip -selection clipboard

# Mostrar notificación (opcional)
notify-send "JWT Secret" "Se ha copiado al portapapeles" -i dialog-information
